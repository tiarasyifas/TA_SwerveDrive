<?xml version="1.0" ?>
<robot name="robotpadi" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find robotpadi_description)/urdf/materials.xacro" />
<xacro:include filename="$(find robotpadi_description)/urdf/robotpadi.ros2control" />
<xacro:include filename="$(find robotpadi_description)/urdf/robotpadi.gazebo" />

<link name="base_link"/>

<joint name="base_link_joint" type="fixed">
  <parent link="base_link"/>
  <child link="base_robot"/>
  <origin xyz="0 0 0.92" rpy="0 0 0"/>  <!-- Raise base_link by the offset -->
</joint>

<link name="base_robot">
  <inertial>
    <origin xyz="4.7605171811971384e-05 7.503713021135889e-06 -1.28855617148301e-05" rpy="0 0 0"/>
    <mass value="111.52248073403692"/>
    <inertia ixx="19.278738" iyy="11.892444" izz="29.802061" ixy="0.058745" iyz="0.077376" ixz="0.004947"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find robotpadi_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="black"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find robotpadi_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

